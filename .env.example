# ── Server ────────────────────────────────────────────────────
# Host port the app is exposed on
PORT=8080

# ── Admin credentials ─────────────────────────────────────────
# Username and password for the /admin panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ── Session ───────────────────────────────────────────────────
# Long random string used to sign session cookies.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=replace-this-with-a-random-secret

# ── Uploads ───────────────────────────────────────────────────
# Maximum upload size in MB
MAX_UPLOAD_MB=50

# ── Reverse proxy ─────────────────────────────────────────────
# Set to 1 when running behind a reverse proxy that terminates HTTPS.
# Enables secure session cookies and correct client IP forwarding.
TRUST_PROXY=0
